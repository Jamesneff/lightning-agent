# OpenRouter (used by parser.py and scorer.py for LLM calls)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Notion integration (used by notion_writer.py)
NOTION_TOKEN=your_notion_integration_token_here
NOTION_DATABASE_ID=your_target_database_id_here

# Web search (used by agents/tools.py)
SERPER_API_KEY=your_serper_api_key_here

# Scraper source credentials (used by scraper.py)
PRODUCTHUNT_API_KEY=your_producthunt_api_key_here
CRUNCHBASE_API_KEY=your_crunchbase_api_key_here
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here

# Deduplication store (used by deduplicator.py)
# Options: "sqlite" (default, local file) or "redis"
DEDUP_BACKEND=sqlite
DEDUP_SQLITE_PATH=./data/seen.db
# DEDUP_REDIS_URL=redis://localhost:6379/0

# Pipeline tuning
SCORER_TOP_N=20          # number of top startups to write to Notion per run
SCRAPER_MAX_RESULTS=100  # max raw results to fetch per source per run
